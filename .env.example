# Global PG config
PG_HOST=metrics_postgres
PG_PORT=5432
PG_DB=pg_db_name
PG_USER=pg_username
PG_PASSWORD=pg_password
PG_SCHEMA=public

# ETL Paths
OPEN_SIGNAL_DATA_PATH="/data/open_signal/os.xlsx"
# ─────────────────────────────────────────
# Global Postgres (App)
# ─────────────────────────────────────────
PG_HOST=metrics_postgres
PG_PORT=5432
PG_DB=pg_db_name
PG_USER=pg_username
PG_PASSWORD=pg_password
PG_SCHEMA=public

# ─────────────────────────────────────────
# Postgres (Service)
# ─────────────────────────────────────────
POSTGRES_DB=db_name
POSTGRES_USER=postgres_username
POSTGRES_PASSWORD=postgres_password

# ─────────────────────────────────────────
# DBT
# ─────────────────────────────────────────
DBT_PROFILE=profile_name
DBT_TARGET=target_name

# ─────────────────────────────────────────
# Kafka (KRaft Mode)
# ─────────────────────────────────────────
KAFKA_KRAFT_MODE='true'

# Unique cluster identifier
CLUSTER_ID='your-cluster-id'

# Broker/controller node ID
KAFKA_NODE_ID=1

# Roles assigned to this node
KAFKA_PROCESS_ROLES=broker,controller

# Controller quorum voters — format=<node_id>@<host>:<controller_port>
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093

# Internal topic replication factor
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# Listener configuration
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093

# External advertised listener
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092

# Controller listener name
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER

# Kafka log storage directory
KAFKA_LOG_DIRS=/tmp/kraft-combined-logs

# ─────────────────────────────────────────
# Airflow
# ─────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=""
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION="true"
AIRFLOW__CORE__LOAD_EXAMPLES="false"
AIRFLOW__API__AUTH_BACKENDS="airflow.api.auth.backend.basic_auth"
AIRFLOW_POSTGRES_USER=airflow_postgres_username
AIRFLOW_POSTGRES_PASSWORD=airflow_postgres_password
AIRFLOW_POSTGRES_DB=airflow_db_name
AIRFLOW__WEBSERVER__SECRET_KEY=secret_key_here
AIRFLOW_CONN_OPEN_SIGNAL_POSTGRES=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────
# ETL Paths
# ─────────────────────────────────────────
OPEN_SIGNAL_DATA_PATH="/data/open_signal/os.xlsx"
HIGH_UTILIZATION_DATA_PATH="/data/open_signal/high_util.csv"
